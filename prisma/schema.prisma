generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GamePhase {
  EXPLORING
  COMBAT
  GAMEOVER
  WIN
  SHOP
  REST
  EVENT
  TREASURE
  LEVELUP
  START_SCREEN
  FLOOR_END
}

enum TileType {
  SAFE
  ENEMY
  KEY
  EXIT
  WALL
  SHOP
  REST
  TREASURE
  EVENT
}

// Elemental cards replacing traditional suits
enum CardElement {
  FIRE
  ICE
  ELECTRICITY
  WIND
}

enum PlayerClass {
  BERSERKER
  PALADIN
  WIZARD
  OVERSEER
}

model User {
  id        String        @id @default(cuid())
  email     String?       @unique
  sessions  GameSession[]
  createdAt DateTime      @default(now())
}

model GameSession {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  phase GamePhase @default(EXPLORING)
  floor Int       @default(1)

  // Player Stats
  playerClass  PlayerClass @default(BERSERKER)
  maxHp        Int         @default(100)
  currentHp    Int         @default(100)
  gold         Int         @default(50)
  currentXP    Int         @default(0)
  level        Int         @default(1)
  relics       String[]    @default([])
  passives     String[]    @default([]) // acquired passive abilities
  hasKey       Boolean     @default(false)
  torchRadius  Int         @default(2)
  baseHandSize Int         @default(8)

  // Player Position
  posX Int @default(0) // axial q
  posY Int @default(0) // axial r

  // Relations
  tiles Tile[]
  deck  Card[]

  inventory             String[]   @default([])

  // Combat State (populated when phase == COMBAT)
  enemyName             String?
  enemyMaxHp            Int?       // Base integrity for enemies (used as their Vigor equivalent if we simplify, but let's keep it maxHp/currentHp for them or rename to vigor)
  enemyCurrentHp        Int?       // They don't have separate Vigor/Health, their HP acts as Vigor
  enemyAttackDamage     Int?
  enemyStatusEffects    Json?      // StatusEffect[] — BURN, FREEZE, CHAIN, PUSH
  playerQueue           String[]   @default([]) // Queue of played card IDs
  enemyQueue            String[]   @default([]) // Queue of enemy intents (Element strings)
  enemyQueueRevealed    Boolean    @default(true) // Hidden if PUSH status is active
  queueSlots            Int        @default(4)    // Slots available to player this turn
  combatMultiplierBonus Float      @default(1.0)  // Stacks from ELECTRICITY chains
  maxVigor              Int        @default(100)
  currentVigor          Int        @default(100)

  // Pending level-up choices (populated when XP threshold crossed)
  pendingLevelUpChoices Json? // LevelUpChoice[]

  // Saved grid when entering sub-rooms (e.g. TREASURE)
  savedGrid Json?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Tile {
  id        String      @id @default(cuid())
  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id])

  q            Int
  r            Int
  type         TileType
  revealed     Boolean  @default(false)
  dangerNumber Int      @default(0)
  hasItem      Boolean  @default(false)

  @@unique([sessionId, q, r])
}

model Card {
  id        String      @id @default(cuid())
  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id])

  element         CardElement
  rank            Int
  isUpgraded      Boolean      @default(false)
  isAsh           Boolean      @default(false)   // true when currentUses hits 0
  isExhaust       Boolean      @default(false)   // if true, card is removed after one use
  currentUses     Int          @default(3)        // remaining uses before becoming Ash
  maxUses         Int          @default(3)        // maximum uses (restored at Rest)
  specialModifier Json? // e.g. { "piercing": true }
  location        CardLocation @default(DECK)
}

enum CardLocation {
  DECK
  HAND
  DISCARD
  SHOP
}
