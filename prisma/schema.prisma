generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GamePhase {
  DASHBOARD
  EXPLORING
  COMBAT
  GAMEOVER
  WIN
  SHOP
  REST
  EVENT
  TREASURE
  LEVELUP
  START_SCREEN
  FLOOR_END
  SPELL_REWARD
}

enum TileType {
  SAFE
  ENEMY
  KEY
  EXIT
  WALL
  SHOP
  REST
  TREASURE
  EVENT
}

enum CardElement {
  FIRE
  WATER
  AIR
  EARTH
}

enum PlayerClass {
  BERSERKER
  PALADIN
  WIZARD
  OVERSEER
}

model User {
  id        String        @id @default(cuid())
  email     String?       @unique
  sessions  GameSession[]
  createdAt DateTime      @default(now())
}

model GameSession {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  phase GamePhase @default(EXPLORING)
  floor Int       @default(1)

  // Player Stats
  playerClass  PlayerClass @default(BERSERKER)
  maxHp        Int         @default(100)
  currentHp    Int         @default(100)
  gold         Int         @default(50)
  currentXP    Int         @default(0)
  level        Int         @default(1)
  relics       String[]    @default([])
  passives     String[]    @default([]) // acquired passive abilities
  hasKey       Boolean     @default(false)
  torchRadius  Int         @default(2)

  // Mana System (queue capacity)
  playerMana Int @default(4) // starts at 4, upgrades to 6 or 8

  // Spare Elements inventory (JSON: { "FIRE": 2, "WATER": 1, "AIR": 0, "EARTH": 3 })
  spareElements Json @default("{\"FIRE\":0,\"WATER\":0,\"AIR\":0,\"EARTH\":0}")

  // Player Position
  posX Int @default(0) // axial q
  posY Int @default(0) // axial r

  // Relations
  tiles  Tile[]
  spells Spell[]

  inventory    String[]   @default([])
  shopRerolled Boolean    @default(false)

  // Combat State (populated when phase == COMBAT)
  enemyName          String?
  enemyTier          Int?       // 1, 2, or 3
  enemyMana          Int?       // enemy queue length (immutable per enemy type)
  enemyMaxHp         Int?
  enemyCurrentHp     Int?
  enemyAttackDamage  Int?
  enemyStatusEffects Json?      // StatusEffect[] — BURN, FREEZE
  enemySpellbook     Json?      // Array of { name, recipe, baseDamage } visible to player
  enemyElementBias   Json?      // { FIRE: 0.75, EARTH: 0.25 } etc.
  playerQueue        String[]   @default([]) // Sequence of CardElement strings e.g. ["FIRE","FIRE","AIR"]
  enemyQueue         String[]   @default([]) // Enemy hidden element sequence
  enemyQueueRevealed Boolean    @default(false) // Always false until post-clash reveal
  isEliteOrBoss      Boolean    @default(false) // Triggers omniscient counter AI

  // Focus and Omen states
  focusPips            Int        @default(0)
  focusAbilityUsed     Boolean    @default(false)
  activeOmen           String?
  lastTurnSpells       String[]   @default([])
  voidElementsNextTurn Int        @default(0)
  revealQueueTurns     Int        @default(0)
  staleTurns           Int        @default(0)


  // Pending level-up choices / rewards
  pendingLevelUpChoices Json?   // LevelUpChoice[] or SpellRewardChoice[]

  // Saved grid when entering sub-rooms (e.g. TREASURE)
  savedGrid Json?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Tile {
  id        String      @id @default(cuid())
  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id])

  q            Int
  r            Int
  type         TileType
  revealed     Boolean  @default(false)
  dangerNumber Int      @default(0)
  hasItem      Boolean  @default(false)
  cleared      Boolean  @default(false)

  @@unique([sessionId, q, r])
}

// Spells replace Cards. A Spell has a recipe (ordered element array),
// base damage, and a tier (Basic or Advanced). Equipped spells contribute
// their recipe elements to the player's combat pool each turn.
model Spell {
  id        String      @id @default(cuid())
  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id])

  name        String
  recipe      Json     // CardElement[] e.g. ["FIRE","FIRE","AIR"]
  baseDamage  Int
  isAdvanced  Boolean  @default(false)
  isUpgraded  Boolean  @default(false)
  equipped    Boolean  @default(false) // true = in active loadout
  location    SpellLocation @default(LIBRARY)
}

enum SpellLocation {
  LIBRARY // owned but not necessarily equipped
  LOADOUT // actively equipped (contributes to pool)
  SHOP    // for sale
}
